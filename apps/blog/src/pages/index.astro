---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n';

const locale = 'ko';
const t = useTranslations(locale);

const posts = (await getCollection('posts'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);

function getSlug(id: string) {
  return id.split('/').at(-1) ?? id;
}
---

<BaseLayout title="jgjgill">
  <section class="space-y-12">
    <div>
      <h1 class="text-2xl font-bold">jgjgill</h1>
      <p class="mt-2 text-muted">{t.home.description}</p>
    </div>

    <div>
      <h2 class="font-semibold mb-4">프로젝트</h2>
      <a
        href="https://my-speak.com"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-4 p-4 rounded-xl border border-border hover:border-accent/30 hover:bg-border/20 transition-colors"
      >
        <div class="shrink-0 w-12 h-12 rounded-xl overflow-hidden bg-[#29ABE2]">
          <img
            src="/my-speak-icon.webp"
            alt="my-speak"
            width="48"
            height="48"
            class="w-full h-full object-cover"
            onerror="this.style.display='none'"
          />
        </div>
        <div class="flex-1 min-w-0">
          <p class="font-medium group-hover:underline underline-offset-2">my-speak</p>
          <p class="text-sm text-muted mt-0.5">언어 학습 플랫폼</p>
        </div>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-muted">
          <path d="M7 7h10v10"/><path d="M7 17 17 7"/>
        </svg>
      </a>
      <a
        href="https://jgjgill.github.io/gs-i18n/"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-4 p-4 rounded-xl border border-border hover:border-accent/30 hover:bg-border/20 transition-colors mt-3"
      >
        <div class="shrink-0 w-12 h-12 rounded-xl overflow-hidden bg-[#5DE6A0]">
          <img
            src="/gs-i18n-icon.webp"
            alt="gs-i18n"
            width="48"
            height="48"
            class="w-full h-full object-cover"
          />
        </div>
        <div class="flex-1 min-w-0">
          <p class="font-medium group-hover:underline underline-offset-2">gs-i18n</p>
          <p class="text-sm text-muted mt-0.5">Google Sheets와 i18next를 활용한 다국어 관리 CLI 도구</p>
        </div>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-muted">
          <path d="M7 7h10v10"/><path d="M7 17 17 7"/>
        </svg>
      </a>
    </div>

    <div>
      <div class="flex items-center justify-between mb-4">
        <h2 class="font-semibold">최근 글</h2>
        <a href="/post" class="text-sm text-muted hover:text-fg transition-colors">
          전체 보기 →
        </a>
      </div>
      <ul class="space-y-4">
        {posts.map((post) => {
          const slug = getSlug(post.id);
          return (
            <li>
              <a href={`/post/${slug}/`} class="group flex gap-3 items-center">
                {post.data.thumbnail && (
                  <div
                    class="shrink-0 w-10 h-10 rounded-md overflow-hidden bg-border"
                    transition:name={`post-thumbnail-${slug}`}
                  >
                    <Image
                      src={post.data.thumbnail}
                      alt={post.data.thumbnail_alt ?? post.data.title}
                      width={80}
                      height={80}
                      class="w-full h-full object-cover"
                    />
                  </div>
                )}
                <div class="flex-1 min-w-0">
                  <p
                    class="font-medium group-hover:underline underline-offset-2 truncate"
                    transition:name={`post-title-${slug}`}
                  >
                    {post.data.title}
                  </p>
                  <p class="text-sm text-muted mt-0.5">{post.data.date}</p>
                </div>
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </section>
</BaseLayout>
